{
  "name": "sinergy-erp-backend-clients",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:run": "ts-node -r tsconfig-paths/register src/database/scripts/run-migrations.ts",
    "migration:revert": "ts-node -r tsconfig-paths/register src/database/scripts/revert-migration.ts",
    "migration:show": "ts-node -r tsconfig-paths/register src/database/scripts/show-migrations.ts",
    "migrate:rbac": "ts-node -r tsconfig-paths/register src/api/rbac/scripts/migrate-users.script.ts",
    "rbac:setup": "ts-node -r tsconfig-paths/register src/api/rbac/scripts/setup-permissions.script.ts setup",
    "rbac:permissions": "ts-node -r tsconfig-paths/register src/api/rbac/scripts/setup-permissions.script.ts permissions",
    "rbac:roles": "ts-node -r tsconfig-paths/register src/api/rbac/scripts/setup-permissions.script.ts roles",
    "rbac:seed": "ts-node -r tsconfig-paths/register src/database/seeds/seed-permissions.ts",
    "rbac:simple-setup": "ts-node -r tsconfig-paths/register src/api/rbac/scripts/simple-setup.script.ts",
    "rbac:complete": "ts-node -r tsconfig-paths/register src/api/rbac/scripts/complete-setup.script.ts",
    "rbac:simple-complete": "ts-node -r tsconfig-paths/register src/api/rbac/scripts/simple-complete-setup.script.ts",
    "rbac:users": "ts-node -r tsconfig-paths/register src/api/rbac/scripts/create-users.script.ts",
    "rbac:migrate-users": "ts-node -r tsconfig-paths/register src/api/rbac/scripts/migrate-users.script.ts",
    "rbac:assign-modules": "ts-node -r tsconfig-paths/register src/database/scripts/assign-modules-to-tenants.ts",
    "import:leads": "ts-node -r tsconfig-paths/register src/database/scripts/import-leads-excel.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.994.0",
    "@aws-sdk/s3-request-presigner": "^3.994.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.0",
    "@nestjs/swagger": "^11.2.5",
    "@nestjs/typeorm": "^11.0.0",
    "@types/multer": "^2.1.0",
    "axios": "^1.13.5",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "commander": "^12.0.0",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.2.3",
    "googleapis": "^171.4.0",
    "jsonwebtoken": "^9.0.3",
    "mysql": "^2.18.1",
    "mysql2": "^3.17.4",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.18.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.28",
    "typeorm-ts-node-commonjs": "^0.3.20",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/commander": "^2.12.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "@types/xlsx": "^0.0.35",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "fast-check": "^4.5.3",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "sqlite3": "^5.1.7",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
